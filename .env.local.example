# === Supabase ===
# Dashboard → Project Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
# Llave publishable/anon (pública, solo para el login de admin)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
# Llave secreta (SOLO servidor, nunca al navegador)
SUPABASE_SECRET_KEY=sb_secret_...

# === App ===
# Emails con acceso al panel admin, separados por coma
ADMIN_EMAILS=admin@ejemplo.com
# Zona horaria del curso (define qué día es "hoy")
COURSE_TIMEZONE=America/Mexico_City
