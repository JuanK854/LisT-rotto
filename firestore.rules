rules_version = '2';

// Todo el acceso a datos pasa por las API routes del servidor (firebase-admin),
// que NO están sujetas a estas reglas. El cliente nunca toca Firestore directo.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
